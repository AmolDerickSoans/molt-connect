{
  "name": "molt-connect-desktop",
  "version": "1.0.0",
  "description": "Molt Connect Desktop - P2P Agent Messaging",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "keywords": [
    "p2p",
    "messaging",
    "agents",
    "ai"
  ],
  "author": "Moltbook",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@molt-connect/sdk": "file:../molt-connect-sdk-2.0.0.tgz",
    "electron-store": "^11.0.2"
  },
  "build": {
    "appId": "com.moltbook.molt-connect-desktop",
    "productName": "Molt Connect",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
